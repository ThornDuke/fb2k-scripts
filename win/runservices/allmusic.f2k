//section> frontmatter ===============================================
//
//   Run services: AllMusic Search
// 
// Restituisce la stringa da passare alla API di AllMusic per
// effettuare una ricerca per <Album Artist>+<Album>
//
// Keybinding: Shift+Ctrl+L
// Label: AllMusic Album + Artist
//
// Author:   Thorn Duke
// Version:  1.2.0
// Date:     2026-05-08
//
//endsection> frontmatter ============================================
//section> atoms
// -------------------------------------------------------------------
//
//   Elementi atomici
//
// -------------------------------------------------------------------
$puts(
  spc,
  ' '
)
$puts(
  plus,
  '+'
)
$puts(
  service,
  'https://www.allmusic.com/search/albums/'
)
//endsection> atoms
//section> tags normalizing
// -------------------------------------------------------------------
//
//   Normalizzazione dei campi
//
// -------------------------------------------------------------------
// 'Various artists' deve essere eliminato nella API di AllMusic
$puts(
  albumArtist,
  $if(
    $stricmp(
      $trim(%album artist%),
      'various artists'
    ),
    $get(null),
    $stripprefix($trim(%album artist%))
  )
)
$puts(
  album,
  $trim(%album%)
)
//endsection> tags normalizing
//section> chars sanitizing
// -------------------------------------------------------------------
//
//   Igienizzazione dei caratteri
//
// -------------------------------------------------------------------
// Invece di effettuare due traslitterazioni (una per ognuno dei campi
// <Album Artist> e <Album>), se ne effettua una sola sulla stringa
// formata dai due campi uniti da uno splitter. La stringa risultante
// verr√† poi "affettata" in corrispondenza dello splitter per ottenere
// le stringhe da utilizzare nella effettiva chiamata alla Api
$puts(
  splitter,
  'ő¶'
)
$puts(
  splitterLength,
  $len($get(splitter))
)
$puts(
  target,
  $get(albumArtist)$get(splitter)$get(album)
)
$puts(
  safeTarget,
  $replace(
    $get(target),
    '!','%'21,'"','%'22,'#','%'23,'$','%'24,
    '%','%'25,'&','%'26,'','%'27,'(','%'28,
    ')','%'29,'*','%'2A,'+','%'2B,',','%'2C,
    '/','%'2F,':','%'3A,';'.'%'3B,'<','%'3C,
    '=','%'3D,'>','%'3E,'?','r%'3F,'@','%'40,
    '[','%'5B,'\','%'5C,']','%'5D,'^','%'5E,
    '`','%'60
  )
)
$puts(
  joinedTarget,
  $replace(
    $get(safeTarget),
    $get(spc),
    $get(plus)
  )
)
$puts(
  sanitizedArtist,
  $substr(
    $get(joinedTarget),
    1,
    $sub(
      $strstr(
        $get(joinedTarget),
        $get(splitter)
      ),
      1
    )
  )
)
$puts(
  sanitizedAlbum,
  $substr(
    $get(joinedTarget),
    $add(
      $strstr(
        $get(joinedTarget),
        $get(splitter)
      ),
      $get(splitterLength)
    ),
    $len($get(joinedTarget))
  )
)
//endsection> chars sanitizing
//section> pieces
// -------------------------------------------------------------------
//
//   Pezzi costitutivi della linea finale
//
// -------------------------------------------------------------------
$puts(
  titlePar,
  $get(sanitizedAlbum)
)
$puts(
  artistPar,
  $if(
    $get(sanitizedArtist),
    $get(plus),
    $get(null)
  )
  $get(sanitizedArtist)
)
$puts(
  params,
  $get(titlePar)$get(artistPar)
)
//endsection> pieces
//section> line building
// -------------------------------------------------------------------
//
//   Costruzione della linea
//
// -------------------------------------------------------------------
$get(service)$get(params)
//endsection> line building
