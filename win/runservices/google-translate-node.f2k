//section> frontmatter ===============================================
//
//   Google Translate with Node
// 
// Prende alcuni tag e li manda come un unico parametro ad uno script
// Node.js che si occupa poi di 'spacchettarli' e mandarli
// eventualmente a Google Translate. I tag contenenti il testo
// della traccia sono prodotti dal componente Open Lyrics.
//
// Author:   Thorn Duke
// Version:  1.1.1
// Date:     2025-10-15
//
//endsection> frontmatter ============================================
//section> atoms
// -------------------------------------------------------------------
//
//   Elementi Atomici
//
// -------------------------------------------------------------------
$puts(
  spc,
  ' '
)
$puts(
  interpreter,
  node
)
$puts(
  script,
  C:\Users\user\Documents\Repositories\fb2k-scripts\interpreted\gtc.js
)
//endsection> atoms
//section> variables
// -------------------------------------------------------------------
//
//   Variabili
//
// -------------------------------------------------------------------
$puts(
  TITLE,
  $if(
    %title%,
    $trim(%title%),
    $get(null)
  )
)
$puts(
  ARTIST,
  $if(
    %artist%,
    $stripprefix(
      $trim(%artist%),
      'The'
    ),
    $get(null)
  )
)
$puts(
  ALBUM,
  $if(
    %album%,
    $trim(%album%),
    $get(null)
  )
)
$puts(
  LYRICS,
  $if3(
    $meta(UNSYNCEDLYRICS),
    $meta(UNSYNCED LYRICS),
    $meta(LYRICS),
    $meta(SYNCEDLYRICS),
    $get(null)
  )
)
//endsection> variables
//section> molecules
// -------------------------------------------------------------------
//
//   Elementi Molecolari
//
// -------------------------------------------------------------------
$puts(
  title_section,
  '<title>'
  $get(TITLE)
  '</title>'
)
$puts(
  artist_section,
  '<artist>'
  $get(ARTIST)
  '</artist>'
)
$puts(
  album_section,
  '<album>'
  $get(ALBUM)
  '</album>'
)
$puts(
  lyrics_section,
  '<lyrics>'
  $get(LYRICS)
  '</lyrics>'
)
//endsection> molecules
//section> organs
// -------------------------------------------------------------------
//
//   Elementi Complessi
//
// -------------------------------------------------------------------
$puts(
  parameters,
  $get(title_section)
  $get(artist_section)
  $get(album_section)
  $get(lyrics_section)
)
//endsection> organs
//section> body
// -------------------------------------------------------------------
//
//   Linea Finale
//
// -------------------------------------------------------------------
$get(interpreter)
$get(spc)
$get(script)
$get(spc)
$get(parameters)
//endsection> body